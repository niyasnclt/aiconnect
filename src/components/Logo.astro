---
interface Props {
  variant?: 'dark' | 'light';
  size?: number;
}

const { variant = 'dark', size = 40 } = Astro.props;
const logoSrc = variant === 'light' ? '/logo-footer.svg' : '/AI-con-Logo.svg';
---

<a class:list={['logo', variant]} href="#top" aria-label="AI Connect Kerala home" style={`--logo-height:${size}px`}>
  <img class="logo-image" src={logoSrc} alt="AI Connect Keralam" loading="eager" decoding="async" />
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }

  .logo-image {
    display: block;
    height: var(--logo-height);
    width: auto;
    max-width: min(44vw, 240px);
  }

  .logo.light .logo-image {
    max-width: min(56vw, 280px);
  }
</style>
