        </svg>
        Follow us on Instagram
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    overflow: hidden;
    background: var(--dark);
    text-align: center;
    padding-block: 100px;
  }
  .cta-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.4;
    z-index: 0;
  }
  .glow-1 { width: 460px; height: 460px; top: -160px; left: -120px; background: var(--blue); }
  .glow-2 { width: 600px; height: 600px; bottom: -260px; right: -120px; background: var(--purple); }
  .glow-3 { width: 240px; height: 240px; top: 30%; left: 45%; background: var(--pink); opacity: 0.3; }

  .cta-inner {
    position: relative;
    z-index: 1;
  }
  .cta-inner h2 {
    margin-top: 16px;
    color: #fff;
    font-size: clamp(34px, 5.4vw, 52px);
    line-height: 1.08;
  }

  .cta-buttons {
    margin-top: 40px;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 26px;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 600;
    color: #fff;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(6px);
    transition: transform 0.18s ease, background-color 0.18s ease, border-color 0.18s ease;
  }
  .social-btn:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
  }
  .social-whatsapp {
    background: linear-gradient(135deg, #25d366, #128c7e);
    border-color: transparent;
    box-shadow: 0 12px 30px -10px rgba(37, 211, 102, 0.6);
  }
  .social-whatsapp:hover {
    background: linear-gradient(135deg, #2ee06f, #14a08f);
  }

  @media (max-width: 600px) {
    .cta {
      padding-block: 72px;
    }
    .social-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
