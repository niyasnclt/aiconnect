---
import { social } from '../data/site';
---

<section class="section cta" id="get-involved">
  <span class="cta-glow glow-1" aria-hidden="true"></span>
  <span class="cta-glow glow-2" aria-hidden="true"></span>
  <span class="cta-glow glow-3" aria-hidden="true"></span>

  <div class="container cta-inner" data-reveal-stagger="90">
    <span class="eyebrow">Get involved</span>
    <h2>Ready to Join Kerala's<br /><span class="grad-text">AI Movement?</span></h2>

    <div class="cta-buttons">
      <a class="social-btn" href={social.linkedin} target="_blank" rel="noopener">
