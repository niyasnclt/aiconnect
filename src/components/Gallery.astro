---
const images = [
  { src: '/gallery/gallery-1.jpg', alt: 'Speaker engaging the audience during an AI Connect Kerala meetup', cls: 'g1' },
  { src: '/gallery/gallery-2.jpg', alt: 'Speaker presenting an AI session with slides', cls: 'g2 tall' },
  { src: '/gallery/gallery-3.jpg', alt: 'Speaker addressing the community with a live demo', cls: 'g3' },
  { src: '/gallery/gallery-4.jpg', alt: 'A full room of attendees at the AI Connect Kerala meetup', cls: 'g4' },
  { src: '/gallery/gallery-5.jpg', alt: 'Members networking during a meetup break', cls: 'g5 tall' },
  { src: '/gallery/gallery-6.jpg', alt: 'Group photo of the AI Connect Kerala community', cls: 'g6' },
  { src: '/gallery/gallery-7.jpg', alt: 'Attendees in discussion outside the venue', cls: 'g7' },
];
---

<section class="section gallery" id="gallery">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">Gallery</span>
      <h2>Community in Action</h2>
      <p>Real moments from our meetups, workshops, and networking events.</p>
    </div>

    <div class="gallery-grid" data-reveal="fade">
      {images.map((img) => (
        <figure class={`gallery-item ${img.cls}`}>
          <img src={img.src} alt={img.alt} loading="lazy" decoding="async" />
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: 170px;
    grid-auto-flow: dense;
  }
  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--bg-softer);
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .gallery-item:hover img {
    transform: scale(1.05);
  }
  .gallery-item.tall {
    grid-row: span 2;
  }

  /* Desktop: 3-column masonry matching the design */
  @media (min-width: 760px) {
    .gallery-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 200px;
    }
    .g1 { grid-area: 1 / 1; }
    .g2 { grid-area: 1 / 2 / span 2; }
    .g3 { grid-area: 1 / 3; }
    .g4 { grid-area: 2 / 1; }
    .g5 { grid-area: 2 / 3 / span 2; }
    .g6 { grid-area: 3 / 1; }
    .g7 { grid-area: 3 / 2; }
  }

  @media (max-width: 520px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    .gallery-item.tall {
      grid-row: span 1;
    }
  }
</style>
