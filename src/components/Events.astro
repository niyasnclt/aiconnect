---
import { Icon } from 'astro-icon/components';
import { social } from '../data/site';

const meta = [
  { icon: 'lucide:map-pin', label: 'Iocod Infotech Private Limited, Kozhikode, Kerala' },
  { icon: 'lucide:calendar', label: '27th June 2026, 10 am to 12 pm' },
  { icon: 'lucide:users', label: 'Offline Meetup' },
];

const learn = [
  'Understanding the Model Context Protocol (MCP) architecture',
  'Building an MCP Server with Laravel to expose custom tools',
  'Connecting AI assistants to real-world application logic',
  'Creating Telegram bots powered by AI',
  'Handling authentication and tool permissions securely',
  'Live demonstration of AI assistants performing real tasks',
  'Best practices for production-ready AI integrations',
];

const demo = [
  'Laravel MCP Server setup',
  'Exposing tools to AI assistants',
  'Telegram bot integration',
  'Real-time tool execution',
  'Live community Q&A',
];

const audience = [
  { icon: 'lucide:code-2', label: 'Laravel Developers' },
  { icon: 'lucide:terminal', label: 'Software Engineers' },
  { icon: 'lucide:bot', label: 'AI Enthusiasts' },
  { icon: 'lucide:rocket', label: 'Startup Founders' },
  { icon: 'lucide:graduation-cap', label: 'Students & Learners' },
  { icon: 'lucide:wrench', label: 'Backend Developers' },
];
---

<section class="section events" id="events">
  <div class="events-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="section-head events-head" data-reveal>
      <span class="eyebrow events-eyebrow">Events</span>
      <h2>Upcoming Events</h2>
      <p>Join us at our next gathering and be part of the conversation.</p>
    </div>

    <article class="event-card" data-reveal="scale">
      <span class="event-topbar" aria-hidden="true"></span>
      <div class="event-body">
        <!-- Left -->
        <div class="event-main">
          <ul class="event-meta">
            <li class="badge-grad">Inaugural Event</li>
            {meta.map((m) => (
              <li class="badge-outline"><Icon name={m.icon} class="badge-icon" aria-hidden="true" />{m.label}</li>
            ))}
          </ul>

          <h3 class="event-title">Model Context Protocol (MCP) in Action</h3>
          <p class="event-subtitle grad-text">Building AI Tools and Telegram Bots with Laravel</p>

          <p class="event-desc">
            Join us for the inaugural AI Connect Kozhikode meetup as we explore one of the most
            exciting developments in the AI ecosystem. We'll demonstrate how a Laravel application can
            expose tools through an MCP Server and how AI assistants can interact with those tools to
            perform real-world tasks.
          </p>

          <h4 class="event-h4">What You'll Learn</h4>
          <ul class="learn-list">
            {learn.map((item) => (
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <circle cx="12" cy="12" r="11" fill="#10b981" opacity="0.14" />
                  <path d="M7.5 12.5l3 3 6-6.5" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {item}
              </li>
            ))}
          </ul>

    <div class="prereq">
    <Icon name="lucide:lightbulb" class="prereq-icon" aria-hidden="true" />
    <p>
        <strong>Prerequisites:</strong>
        Basic understanding of PHP and Laravel is helpful but not required.
        Bring your laptop to follow along with the live demo.
    </p>
    </div>

        <!-- Right -->
        <aside class="event-side">
          <div class="demo-box">
            <h4 class="event-h4"><Icon name="lucide:video" class="demo-icon" aria-hidden="true" /> Live Demo</h4>
            <ul class="demo-list">
              {demo.map((d) => <li><span class="dot" aria-hidden="true"></span>{d}</li>)}
            </ul>
          </div>

          <h4 class="event-h4">Who Should Attend?</h4>
          <ul class="audience-list">
            {audience.map((a) => (
              <li><Icon name={a.icon} class="aud-icon" aria-hidden="true" />{a.label}</li>
            ))}
          </ul>

          <div class="share-row">
            <span class="share-label">Share:</span>
            <a href={social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            <a href="#events">Twitter</a>
            <a href="#events">Copy</a>
          </div>

          <div class="register-btn-wrap">
            <a
              href="https://luma.com/event/evt-lqwFQ1tcLpLuZzU"
              class="luma-checkout--button"
              data-luma-action="checkout"
              data-luma-event-id="evt-lqwFQ1tcLpLuZzU"
            >
              Register for Event
            </a>
          </div>
          <p class="register-note">Limited seats available · Free entry for all members</p>
        </aside>
      </div>
    </article>
  </div>
</section>

<style>
  .events {
    position: relative;
    overflow: hidden;
    color: #fff;
  }
  .events-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 60% at 8% 0%, rgba(59, 130, 246, 0.55), transparent 60%),
      radial-gradient(55% 60% at 100% 100%, rgba(236, 72, 153, 0.55), transparent 60%),
      linear-gradient(135deg, #1d4ed8 0%, #7c3aed 48%, #db2777 100%);
    z-index: -1;
  }
  .events-head h2 {
    color: #fff;
  }
  .events-eyebrow {
    -webkit-text-fill-color: rgba(255, 255, 255, 0.92);
    background: none;
    color: rgba(255, 255, 255, 0.92);
  }
  .events-head p {
    color: rgba(255, 255, 255, 0.85);
  }

  .event-card {
    position: relative;
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: 0 30px 70px -20px rgba(15, 23, 42, 0.5);
    overflow: hidden;
    color: var(--text);
  }
  .event-topbar {
    display: block;
    height: 6px;
    background: var(--brand-gradient);
  }
  .event-body {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
  }
  .event-main {
    padding: 40px;
    border-right: 1px solid var(--border);
  }
  .event-side {
    padding: 40px;
  }

  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .badge-grad,
  .badge-outline {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
  }
  .badge-grad {
    background: var(--brand-gradient);
    color: #fff;
  }
  .badge-outline {
    border: 1px solid var(--border);
    color: var(--text-2);
  }

  .event-title {
    margin-top: 22px;
    font-size: clamp(26px, 3.2vw, 34px);
    color: var(--ink);
    line-height: 1.15;
  }
  .event-subtitle {
    margin-top: 8px;
    font-size: 19px;
    font-weight: 600;
    font-family: var(--font-display);
  }
  .event-desc {
    margin-top: 20px;
    font-size: 15.5px;
    color: var(--text);
  }

  .event-h4 {
    font-size: 18px;
    color: var(--ink);
  }
  .learn-list {
    margin-top: 18px;
    display: grid;
    gap: 12px;
  }
  .learn-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    color: var(--text);
  }
  .learn-list svg {
    flex-shrink: 0;
    margin-top: 1px;
  }
  .event-main .event-h4:nth-of-type(1) {
    margin-top: 32px;
  }

  .prereq {
    margin-top: 28px;
    display: flex;
    gap: 12px;
    padding: 16px 18px;
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(236, 72, 153, 0.06));
    border: 1px solid rgba(245, 158, 11, 0.25);
  }
  .prereq-icon {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: #f59e0b;
    margin-top: 1px;
  }
  .prereq p {
    font-size: 14px;
    color: var(--text);
  }

  /* Right column */
  .demo-box {
    padding: 22px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(24, 119, 242, 0.06), rgba(168, 85, 247, 0.06));
    border: 1px solid rgba(168, 85, 247, 0.18);
  }
  .demo-box .event-h4 {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .demo-icon {
    width: 18px;
    height: 18px;
    color: var(--purple-600);
  }
  .demo-list {
    margin-top: 16px;
    display: grid;
    gap: 10px;
  }
  .demo-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14.5px;
    color: var(--text);
  }
  .demo-list .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-gradient);
    flex-shrink: 0;
  }

  .event-side > .event-h4 {
    margin-top: 32px;
  }
  .audience-list {
    margin-top: 16px;
    display: grid;
    gap: 8px;
  }
  .audience-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ink-2);
    transition: border-color 0.18s ease, background-color 0.18s ease;
  }
  .aud-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--purple-600);
  }
  .badge-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
  .audience-list li:hover {
    border-color: rgba(168, 85, 247, 0.4);
    background: rgba(168, 85, 247, 0.04);
  }

  .share-row {
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 14px;
  }
  .share-label {
    color: var(--muted);
  }
  .share-row a {
    color: var(--purple-600);
    font-weight: 600;
  }
  .share-row a:hover {
    text-decoration: underline;
  }

  .register-btn-wrap {
    margin-top: 24px;
    display: flex;
    justify-content: center;
  }
  .register-note {
    margin-top: 14px;
    text-align: center;
    font-size: 13px;
    color: var(--muted);
  }

  @media (max-width: 880px) {
    .event-body {
      grid-template-columns: 1fr;
    }
    .event-main {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .event-main,
    .event-side {
      padding: 28px;
    }
  }
</style>
