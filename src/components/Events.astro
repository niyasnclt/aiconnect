---
import { Icon } from 'astro-icon/components';
import { social } from '../data/site';

const meta = [
  { icon: 'lucide:map-pin', label: 'EMS Seminar Hall, University of Calicut' },
  { icon: 'lucide:calendar', label: 'July 18, 2026 · Saturday' },
  { icon: 'lucide:clock', label: '10:00 – 13:00 · Doors open early' },
];

const speakers = [
  {
    tag: 'Speaker 01',
    initials: 'RJ',
    name: 'Reema Jaleel',
    role: 'CEO & Co-founder, Resab Technologies LLP',
    topic: 'Beyond Intelligence: Designing AI Systems with Memory and Evaluation',
  },
  {
    tag: 'Speaker 02',
    initials: 'SC',
    name: 'Shinoj CM',
    role: 'CEO, ExodeUI',
    topic: 'How We Build Cursor for Motion',
  },
];
---

<section class="section events" id="events">
  <div class="events-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="section-head events-head" data-reveal>
      <span class="eyebrow events-eyebrow">Upcoming Event · Malappuram</span>
      <h2>Meet Our Speakers</h2>
      <p>July's AI Connect Keralam meetup is happening in Malappuram, and here's who's taking the stage.</p>
    </div>

    <article class="event-card" data-reveal="scale">
      <span class="event-topbar" aria-hidden="true"></span>
      <div class="event-inner">
        <ul class="event-meta">
          <li class="badge-grad">Speaker Lineup</li>
          {meta.map((m) => (
            <li class="badge-outline"><Icon name={m.icon} class="badge-icon" aria-hidden="true" />{m.label}</li>
          ))}
        </ul>

        <div class="speakers">
          {speakers.map((s) => (
            <article class="speaker-card">
              <div class="speaker-head">
                <div class="speaker-avatar" aria-hidden="true">{s.initials}</div>
                <div class="speaker-id">
                  <span class="speaker-tag">{s.tag}</span>
                  <h3 class="speaker-name">{s.name}</h3>
                  <p class="speaker-role">{s.role}</p>
                </div>
              </div>
              <div class="speaker-topic">
                <span class="topic-label">Topic</span>
                <p class="topic-text">{s.topic}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="event-cta">
          <div class="register-btn-wrap">
            <a
              href="https://luma.com/event/evt-gtl4DZNfHlEfbHN"
              class="luma-checkout--button btn btn-primary"
              data-luma-action="checkout"
              data-luma-event-id="evt-gtl4DZNfHlEfbHN"
            >
              Register for Event
            </a>
          </div>
          <p class="register-note">Limited seats available · Free entry for all members</p>

          <div class="share-row">
            <span class="share-label">Share:</span>
            <a href={social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            <a href={social.whatsapp} target="_blank" rel="noopener">WhatsApp</a>
            <a href="#events">Copy</a>
          </div>
        </div>
      </div>
    </article>
  </div>
</section>

<style>
  .events {
    position: relative;
    overflow: hidden;
    color: #fff;
  }
  .events-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 60% at 8% 0%, rgba(59, 130, 246, 0.55), transparent 60%),
      radial-gradient(55% 60% at 100% 100%, rgba(236, 72, 153, 0.55), transparent 60%),
      linear-gradient(135deg, #1d4ed8 0%, #7c3aed 48%, #db2777 100%);
    z-index: -1;
  }
  .events-head h2 {
    color: #fff;
  }
  .events-eyebrow {
    -webkit-text-fill-color: rgba(255, 255, 255, 0.92);
    background: none;
    color: rgba(255, 255, 255, 0.92);
  }
  .events-head p {
    color: rgba(255, 255, 255, 0.85);
  }

  .event-card {
    position: relative;
    background: #fff;
    border-radius: var(--radius-xl);
    box-shadow: 0 30px 70px -20px rgba(15, 23, 42, 0.5);
    overflow: hidden;
    color: var(--text);
    max-width: 960px;
    margin-inline: auto;
  }
  .event-topbar {
    display: block;
    height: 6px;
    background: var(--brand-gradient);
  }
  .event-inner {
    padding: 40px;
  }

  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .badge-grad,
  .badge-outline {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
  }
  .badge-grad {
    background: var(--brand-gradient);
    color: #fff;
  }
  .badge-outline {
    border: 1px solid var(--border);
    color: var(--text-2);
  }
  .badge-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Speakers */
  .speakers {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .speaker-card {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding: 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(24, 119, 242, 0.04), rgba(168, 85, 247, 0.05));
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .speaker-card:hover {
    transform: translateY(-3px);
    border-color: rgba(168, 85, 247, 0.35);
    box-shadow: var(--shadow-lg);
  }
  .speaker-head {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .speaker-avatar {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--brand-gradient);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.02em;
  }
  .speaker-tag {
    display: inline-block;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--purple-600);
    background: rgba(168, 85, 247, 0.1);
    padding: 3px 10px;
    border-radius: 999px;
  }
  .speaker-name {
    margin-top: 9px;
    font-size: 22px;
    color: var(--ink);
    line-height: 1.15;
  }
  .speaker-role {
    margin-top: 5px;
    font-size: 14px;
    color: var(--text-2);
  }
  .speaker-topic {
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .topic-label {
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .topic-text {
    margin-top: 7px;
    font-family: var(--font-display);
    font-size: 16.5px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--ink);
  }

  /* CTA */
  .event-cta {
    margin-top: 32px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    text-align: center;
  }
  .register-btn-wrap {
    display: flex;
    justify-content: center;
  }
  .register-note {
    margin-top: 14px;
    font-size: 13px;
    color: var(--muted);
  }
  .share-row {
    margin-top: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-size: 14px;
  }
  .share-label {
    color: var(--muted);
  }
  .share-row a {
    color: var(--purple-600);
    font-weight: 600;
  }
  .share-row a:hover {
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .event-inner {
      padding: 28px;
    }
    .speakers {
      grid-template-columns: 1fr;
    }
  }
</style>
